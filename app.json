{
  "expo": {
    "name": "SubEase",
    "slug": "subease",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icons/logo-white.png",
    "scheme": "subease",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/images/splash-v2.png",
        "resizeMode": "contain",
        "backgroundColor": "#4A55F2"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A55F2",
        "foregroundImage": "./assets/icons/logo-white.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/logo-white.png"
    },
    "splash": {
      "image": "./assets/images/splash-v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A55F2"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-v2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4A55F2",
          "dark": {
            "backgroundColor": "#4A55F2"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
